{
  "manifest_version": 3,
  "name": "Solution Tracker",
  "version": "1.0",
  "description": "Automatically documents coding solutions to GitHub via local API.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "*://leetcode.com/*",
    "*://*.geeksforgeeks.org/*",
    "*://*.hackerrank.com/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://leetcode.com/problems/*"],
      "js": ["content/leetcode.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.geeksforgeeks.org/problems/*"],
      "js": ["content/gfg.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.hackerrank.com/challenges/*"],
      "js": ["content/hackerrank.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  }
}
